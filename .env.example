# Edufix LMS Environment Variables Template
# Copy this file to .env and fill in the values

# Security
DEBUG=True
SECRET_KEY=django-insecure-replace-this-with-a-very-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,edufixacademy.com

# Email Configuration
EMAIL_HOST_USER=academyedufix@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# AI Chatbot
OPENAI_API_KEY=your-openai-api-key-here

# Database (Optional: uncomment for PostgreSQL)
# DB_NAME=edufix_db
# DB_USER=dbuser
# DB_PASSWORD=dbpassword
# DB_HOST=localhost
# DB_PORT=5432
